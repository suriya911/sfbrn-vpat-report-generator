# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.installed.cfg

# Virtual environments
.venv/
venv/
env/
ENV/

# ── Build / packaging ────────────────────────────────────────────────────────
build/
dist/
*.spec.bak
*.manifest

# ── Tooling caches ───────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ── Editors / OS ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── App-generated artifacts ──────────────────────────────────────────────────
# Demo/report PDFs are produced by make_demo.py / the app; regenerate, don't commit.
demo_*.pdf
*_VPAT_Report.pdf

# PyInstaller build log and the self-test output are transient.
build_log.txt
vpat_selftest.json

# Corpus scoreboard output (tools/corpus_report.py --json). The committed
# baseline lives at tools/corpus_baseline.json; these runs are throwaway.
.corpus/

# Generated reports and their JSON records. Regenerate with:
#   python -m vpat_reviewer.cli review <vpat> -o out/<name>.pdf
out/
